# Backend Secrets (Critical) - DO NOT SHARE
# Gemini API Keys (Round-Robin Load Balancing)
# Use GEMINI_API_KEY_1, GEMINI_API_KEY_2, etc. for load balancing across multiple keys
# If only one key, use GEMINI_API_KEY
GEMINI_API_KEY_1=AIza...
GEMINI_API_KEY_2=AIza...
GEMINI_API_KEY_3=AIza...

SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Shared Public Keys (Frontend & Backend)
NEXT_PUBLIC_SUPABASE_URL=https://...
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_pub_...

# SEO
NEXT_PUBLIC_BASE_URL=https://bodoge-no-mikata.vercel.app

# Optional
GEMINI_MODEL=models/gemini-3-flash-preview
AMAZON_TRACKING_ID=bodogemikata-22
